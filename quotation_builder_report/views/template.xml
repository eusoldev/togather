<?xml version="1.0"?>
<odoo>

        <record id="quotation_builder_report_template" model="report.paperformat">
            <field name="name">Quotation Builder Report</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">0</field>
            <field name="margin_right">0</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">10</field>
            <field name="dpi">90</field>
        </record>





        <record id="quotation_builder_report_template_email" model="report.paperformat">
            <field name="name">Quotation Builder Report Pro</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">0</field>
            <field name="margin_left">5</field>
            <field name="margin_right">8</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">10</field>
            <field name="dpi">90</field>
        </record>



        <report
            id="quotation_report_id" 
            model="quotation.builder"
            name="quotation_builder_report.quotation_builder_report"
            file="quotation_builder_report.quotation_builder_report"
            report_type="qweb-pdf"
            paperformat="quotation_builder_report_template"
            print_report_name="'%s - %s' %(object.subject, object.sr_no)"
            string="Quotation Builder(English)"
            />
            <!-- print_report_name="(object.subject)" -->
        <report
            id="quotatipon_builder_report" 
            model="quotation.builder"
            name="quotation_builder_report.quotation_builder_arabic"
            file="quotation_builder_report.quotation_builder_arabic"
            report_type="qweb-pdf"
            paperformat="quotation_builder_report_template"
            print_report_name="'%s - %s' %(object.subject, object.sr_no)"
            string="Quotation Builder (Arabic)"
            />



