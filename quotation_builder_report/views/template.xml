            <record id="quotatipon_builder_report_new_one" model="ir.actions.report">
            <field name="name">Quotation Builder (Pro)</field>
            <field name="model">quotation.builder</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">quotation_builder_report.quotation_builder_email_t</field>
            <field name="report_file">quotation_builder_report.quotation_builder_email_t</field>
            <field name="print_report_name">'Quotation Builder (Pro) - %s' % (object.sr_no )</field>
            <field name="binding_model_id" ref="quotation_builder.model_quotation_builder" />
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="quotation_builder_report_template_email" />
        </record>



     

    <template id="external_layout_custome">
        <t t-if="not o" t-set="o" t-value="doc"/>
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id"/>
            </t>
            <t t-elif="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id.sudo()"/>
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company"/>
            </t>
        </t>
        <t t-if="not o" t-set="o" t-value="doc"/>
        
