<odoo>
    <data>
        <record model="ir.ui.view" id="reservation_link_ext">
            <field name="name">reservation_form_ext</field>
            <field name="model">reservation.link.model</field>
            <field name="arch" type="xml">
                <form string="Reservation Link">
                    <group>
                        <field name="reservation_link_ref" required="0" readonly="1" />
                        <field name="resvartion_link_id" required="0" readonly="1" />
                        <field name="reservation_link_email" required="1" readonly="0" />
                        <field name="reservation_link" required="0" readonly="1" widget="CopyClipboardChar"/>
                        
                    </group>
                    <footer>
                        <button name="send_reservation_email_to_customer" type="object" string="Send Email" class="oe_highlight" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>
        <record id="reservation_link_button" model="ir.ui.view">
            <field name="name">reservation_link_button</field>
            <field name="model">reservation.order</field>
            <field name="inherit_id" ref="travel_package.view_reservation_order_form" />
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_voucher_sent']" position="after">
                    <button name="reservation_button_link" string="Generate Reservation Link" type="object" class="oe_highlight" groups="reservation_link.reservation_link_security" invisible="stages in ('draft','cancel')" />
                </xpath>
                 <xpath expr="//page[@name='term_conditions']" position="after">
                <page string='Customer Note'>
                    <group>
                        <group>
                           <field name="customer_note"  readonly="1"/>
                        </group>
                        
                    </group>
                </page>
                </xpath>
            </field>
        </record>
        
    </data>
</odoo>