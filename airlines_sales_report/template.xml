<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="_airlinecustom_sales_reports" model="report.paperformat">
            <field name="name">Page For Airline Sales Report</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">10</field>
            <field name="dpi">90</field>
        </record>
        
        
        <record id="report_airline_sales_report" model="ir.actions.report">
            <field name="name">Airline Report</field>
            <field name="model">air.sales.report</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">airlines_sales_report.airlines_sales_report</field>
            <field name="report_file">airlines_sales_report.airlines_sales_report</field>
            <field name="print_report_name">Airline Report</field>
            <field name="attachment"/>
            <field name="binding_model_id" ref="airlines_sales_report.model_air_sales_report"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="_airlinecustom_sales_reports" />
        </record>

        <record id="airline_sale_report_wizard" model="ir.ui.view">
            <field name="name">airline_sale_report_wizard</field>
            <field name="model">air.sales.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report">
                    <group name="group_top">
                        <group name="group_left">
                            <field name="date_range" />
                            <field name="is_com" />
                            <field name="form" />
                            <field name="country_id" options="{'no_open':True,'no_create': True}" />
                            <field name="company_id" invisible="1" />
                            <field name="booking_type" required="1" />
                        </group>
                        <group name="group_right">
                            <!-- <field name="print_excel"/> -->
                            <field name="partner_id" widget="many2many_tags" options="{'no_open':True,'no_create': True}" required="1"/>
                            <field name="to" />
                            <field name="hotel" domain="[('hotel_supplier','=',True)]" options="{'no_open':True,'no_create': True}" invisible="1" />
                        </group>
                    </group>
                    <footer style="height: 30px !important; border: none !important;">
                        <button name="generate_report" type="object" string="Print" class="oe_highlight" />
                    </footer>
                </form>
            </field>
        </record>
       
        <record id="airline_custom_menu" model="ir.actions.act_window">
            <field name="name">Airline Sale Report</field>
            <field name="res_model">air.sales.report</field>
            <!-- <field name="view_type">form</field> -->
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="airline_sale_report_wizard" />
            <field name="target">new</field>
        </record>
        <menuitem id="airline_custom_menuitem" name="Airline Sale Report" action="airline_custom_menu" parent="account.menu_finance_reports" groups="airlines_sales_report.security_group_for_airlines_sales_report" />

       <template id="airlines_sales_report_tempalate">
            <style type="text/css">
            
            </style>
            <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" />
            <t t-if="not o" t-set="o" t-value="doc" />
            <t t-if="not company">
                <t t-if="company_id">
                    <t t-set="company" t-value="company_id" />
                </t>
                <t t-elif="o and 'company_id' in o">
                    <t t-set="company" t-value="o.company_id.sudo()" />
                </t>
                <t t-else="else">
                    <t t-set="company" t-value="res_company" />
                </t>
            </t>
            <div class="o_background_header" style="min-height: 190px !important;">
                <div class="float-right">
                    <h3 class="mt0 text-right" t-field="company.report_header" />
                </div>
                <div class="main_div" style="width:100%;">
                    <div class="left_div" style="float:left; width:39%;margin-left:20px;height:0px">
                        <t t-tif="company.logo">
                            
                            <img  style="float:left;width:50%; margin-top:10px;height:100px; margin-left:10px" t-if="company.logo" t-att-src="image_data_uri(company.logo)"/>
                        </t>
                    </div>
                    <div class="right_div" style="float:right; width:27%; margin:0px;text-align:start;">
                        <p style="font-weight: bold;font-size: 18px;color:#927f73;">
                            <span>Contact Us:</span>
                        </p>
                      
                        <p style="margin:0px;;color:#927f73;font-size:18px">
                            <!-- <span class="solid">Phone No:</span> -->
                            <span class="liquid" t-esc="company.phone"></span>
                        </p>
                        <p style="margin:0px;;color:#927f73;font-size:18px">
                            <span class="solid">Email:</span>
                            <span class="liquid" t-esc="company.email"></span>
                        </p>
                        <p style="margin:0px;;color:#927f73;font-size:18px">
                            <span class="solid" style="font-weight:bold;font-size:18px">Offices Address:</span>
                            <span class="liquid">Riyadh | Jeddah | Dubai</span>
                        </p>
                        <br />
                        <p style="margin:0px;">
                            
                            <span class="solid">
                                <a t-att-href="company.social_instagram" style="color:white">
                                    <i class="fab fa-instagram" style="color:#927f73; font-size:30px; margin-right:12px;"></i>
                                </a>
                            </span>
                            <span class="solid">
                                <a t-att-href="company.social_facebook" style="color:white">
                                    <i class="fab fa-facebook" style="color:#927f73; font-size:30px;margin-right:12px;"></i>
                                </a>
                            </span>
                            <span class="solid">
                                <a t-att-href="company.social_youtube" style="color:white">
                                    <i class="fab fa-snapchat-square" style="color:#927f73; font-size:30px; margin-right:12px;"></i>
                                </a>
                            </span>
                            <span class="solid">
                                <a t-att-href="company.social_linkedin" style="color:white">
                                    <i class="fab fa-linkedin" style="color:#927f73; font-size:30px; margin-right:12px;"></i>
                                </a>
                            </span>
                           <span class="solid">
                                <a t-att-href="company.social_twitter" style="color:white">
                                    <!-- <i class="fab fa-twitter-square" style="color:#927f73; font-size:30px;"></i> -->
                                    <img src="/voucher_report/static/src/img/twitter.png" style="width:6.8%;color: #927f73;margin-top: -18px;" />
                                </a>
                            </span>
                        </p>
                    </div>
                </div>
            </div>
            <t t-raw="0" />
        </template>
    </data>
</odoo>