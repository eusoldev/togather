<odoo>
    <data noupdate="0">
        <record model="ir.module.category" id="custom_weekly_reportsss">
            <field name="name">Weekly Report</field>
            <field name="sequence">14</field>
        </record>
        <record model="res.groups.privilege" id="weekly_report_privilege">
            <field name="name">Weekly Report</field>
            <field name="category_id" ref="custom_weekly_reportsss"/>
        </record>
        <!-- 
        <record id="security_group_for_weekly_report" model="res.groups">
            <field name="name">Security Group For weekly_report</field>
        </record> -->
        <record id="security_group_for_draft_reports" model="res.groups">
            <field name="name">security group for weekly draft reports</field>
             <field name="user_ids" eval="[Command.link(ref('base.user_admin'))]"/>
        </record>
        <record id="security_group_for_validate_reports" model="res.groups">
            <field name="name">security group for weekly validate reports</field>
             <field name="user_ids" eval="[Command.link(ref('base.user_admin'))]"/>
        </record>




        <record id="group_weekly_custom_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]" />
            <field name="privilege_id" ref="weekly_report_privilege" />
        </record>

        <record id="group_weekly_custom_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="implied_ids" eval="[Command.link(ref('group_weekly_custom_user'))]" />
            <field name="user_ids" eval="[Command.link(ref('base.user_admin'))]"/>
            <field name="privilege_id" ref="weekly_report_privilege" />
        </record>

        
        <record id="weekly_admin_access_c_rule" model="ir.rule">
            <field name="name">Admin Access For Weekly Report</field>
            <field name="model_id" ref="model_weekly_form" />
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="global" eval="False" />
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="1" />
            <field name="perm_create" eval="1" />
            <field name="perm_unlink" eval="1" />
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('weekly_report.group_weekly_custom_admin'))]" />
        </record>
        <record id="weekly_user_access_c_rule" model="ir.rule">
            <field name="name">User Weekly Report Access</field>
            <field name="model_id" ref="model_weekly_form" />
            <field name="global" eval="False" />
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="1" />
            <field name="perm_create" eval="1" />
            <field name="perm_unlink" eval="0" />
            <field name="domain_force">[('employee_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('weekly_report.group_weekly_custom_user'))]" />
        </record>
    </data>
</odoo>