<odoo>
    <data>
        <record id="weekly_report_form" model="ir.ui.view">
            <field name="name">weekly_report_form</field>
            <field name="model">weekly.form</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="button_draft" string=" Draft" type="object" class="btn-primary" invisible='1' />
                        <!-- attrs="{'invisible': [('state', 'in', ['draft'])]}" -->
                        <button name="button_verified" string="Submitted" type="object" class="btn-primary"  invisible="state =='sub'"  confirm="Are you sure to submit this file "/>
                        <!-- <button name="button_confirm" string="Confirm" type="object" class="btn-primary" attrs="{'invisible': [('state', 'in', ['confirm','sub'])]}" confirm="Are You confirm Without Attchment File" invisible="1" /> -->
                        <field name="state" widget="statusbar" />
                        <!-- statusbar_visible="confirm,draft,submitted" -->
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <!-- <field name="s_no" readonly="1" /> -->
                            </h1>
                        </div>

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True" />
                        <group>
                            <group>
                                <field name="date_From" options="{'no_create': True, 'no_create_edit':True,'no_open':True,}"    readonly="1" force_save="1"/>
                                <field name="employee_id"  required='1' options="{'no_create': True, 'no_create_edit':True,'no_open':True,}" readonly="1"/>
                                <field name="attachment_id" widget="binary" readonly="state =='sub'"/>
                                <field name="week_field" readonly="1" force_save="1"/>
                                
                            </group>
                            <group>
                                <field name="date_to"  readonly="1" force_save="1" />
                                <field name="employee_department" options="{'no_create': True, 'no_create_edit':True,'no_open':True,}"  readonly="1" force_save='1'/>
                                <field name="week" invisible="1"/>
                                <field name="active" groups="weekly_report.security_group_for_validate_reports"/>
                                <field name="get_id" invisible="1" />
                                <field name="get_ids" invisible="1" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Detail">
                                <field name="task_detail" readonly="state =='sub'"/>
                            </page>
                            <page string="Comment">

                                <group>
                                    
                                <field name="report_comments" readonly="get_ids !=12" />
                                </group>

                                <field name="check_c" string="Re-Comment" invisible="1" />

                            </page>
                            <page string="Reply">
                                <group>
                                <field name="report_replys"/>
                                     <!-- attrs="{'readonly': ['|',('state','in',['sub']),('check_c_r','in',['three','two'])]}" -->
                                </group>
                                <field name="check_c_r" invisible="1" />
                            </page>
                        </notebook>

                    </sheet>
                    <chatter/>
                    
                </form>
            </field>
        </record>
        <record id="weekly_report_tree" model="ir.ui.view">
            <field name="name">weekly_report_tree</field>
            <field name="model">weekly.form</field>
            <field name="arch" type="xml">
                <list string="Tree">
                    <field name="employee_id" />
                    <field name="employee_department" />
                    <field name="date_From" force_save="1"/>
                    <field name="date_to" force_save="1" />
                    <field name="state" />
                </list>
            </field>
        </record>
        <record id="action_weekly_report_action" model="ir.actions.act_window">
            <field name="name">Weekly Report</field>
            <field name="res_model">weekly.form</field>
            <field name="view_mode">list,form</field>
            
        </record>
        <menuitem id="Weekly_Report" name="Weekly Report" web_icon="weekly_report,static/description/icon.png/" sequence='1' />
        <!-- 2nd action -->
        <record id="action_for_draft_weekly_report" model="ir.actions.act_window">
            <field name="name">Weekly Report</field>
            <field name="res_model">weekly.form</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'draft')]</field>
            <field name="context" eval="{'default_active': 1}"/>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('weekly_report_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('weekly_report_form')})]" />
        </record>
        <record id="action_weekly_report_action_validat" model="ir.actions.act_window">
            <field name="name">Weekly Report</field>
            <field name="res_model">weekly.form</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'sub')]</field>
            <field name="context" eval="{'default_active': 1}"/>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('weekly_report_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('weekly_report_form')})]" />
        </record>
        <menuitem id="Weekly_Report_2nd" name="Weekly Report" sequence='2' parent='Weekly_Report' />

        <menuitem id="Weekly_Report_4rd" name="Weekly Report Draft" sequence='1' parent='Weekly_Report_2nd' action='action_for_draft_weekly_report'  groups='weekly_report.security_group_for_draft_reports'/>

        <menuitem id="Weekly_Report_5rd" name="Weekly Report Submitted" sequence='1' parent='Weekly_Report_2nd' action='action_weekly_report_action_validat' groups='weekly_report.security_group_for_validate_reports'  />

