        <record id="view_users_form_inherit_for_week_report" model="ir.ui.view">
            <field name="name">res.users.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='other_preferences']" position="inside">
                    <field name="weekly_report"/>
                </xpath>
            </field>
        </record>









        <record id="virew_res_partners_inherit_exx" model="ir.ui.view">
            <field name="name">res.partner.form.ex</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="string">Vat ID</attribute>
                </xpath>
            </field>
        </record>






        <record id="virew_res_cmm_partners_inherit_exx" model="ir.ui.view">
                <field name="name">res.company.form.exxs</field>
                <field name="model">res.company</field>
                <field name="inherit_id" ref="base.view_company_form"/>
                <field name="arch" type="xml">
                    <xpath expr="//field[@name='vat']" position="attributes">
                        <attribute name="string">Vat ID</attribute>
                    </xpath>

                    <xpath expr="//field[@name='vat']" position="after">

                        <field name="custom_cr_number"></field>
                    </xpath>
                </field>
            </record>







    </data> 
