<?xml version="1.0"?>
<odoo>
    <data>
        <record id="voucher_report_template" model="report.paperformat">
            <field name="name">Voucher</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">0</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">10</field>
            <field name="dpi">90</field>
        </record>
        <record id="voucher_report_id" model="ir.actions.report">
            <field name="name">Confirmation Report (View)</field>
            <field name="model">reservation.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">voucher_report.voucher_report_report</field>
            <field name="report_file">voucher_report.voucher_report_report</field>
            <field name="print_report_name">'Confirmation - %s' % (object.name)</field>
            <field name="binding_model_id" ref="travel_package.model_reservation_order" />
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="voucher_report_template" />
        </record>
        <record id="voucher_report_pdf_id" model="ir.actions.report">
            <field name="name">Confirmation Report(Download)</field>
            <field name="model">reservation.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">voucher_report.voucher_report_report</field>
            <field name="report_file">voucher_report.voucher_report_report</field>
            <field name="print_report_name">'Confirmation - %s' % (object.name)</field>
            <field name="binding_model_id" ref="travel_package.model_reservation_order" />
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="voucher_report_template" />
        </record>
        <!-- <template id="external_layout_header_inherit_cr" inherit_id="web.internal_layout">
            <xpath expr="//div[@class='header']" position="replace">
                <div class="header">
                </div>
            </xpath>
        </template> -->
    </data>
</odoo>