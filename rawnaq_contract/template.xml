<?xml version="1.0"?>
<odoo>
	<data>
		<record id="contracr_form_view" model="ir.ui.view"> 
			<field name="name">Service Contract</field> 
			<field name="model">contract.form</field> 
			<field name="arch" type="xml"> 
			<form string="Form" >
				<header>
					<button name="action_set_new" string="New" type="object" class="oe_highlight"  invisible="state in ('new','renew','expired','cancel')"/>

					<button name="action_set_running" string="Running" type="object" class="oe_highlight" invisible="state in ('running','expired','cancel')" />

					<button name="action_set_renew" string="Renew" type="object" class="oe_highlight" invisible="state in ('new','renew','expired','cancel')"/>

					<button name="action_set_expired" string="Expired" type="object" class="oe_highlight" invisible="state in ('new','renew','expired','cancel')"/>

					<button name="action_set_cancel" string="Cancel" type="object" class="oe_highlight" />
					<field name="state" widget="statusbar"/>
				</header>
				<sheet>
					<group name="group_first">
						<h1>
							<field name="name" placeholder="Contract Reference"  readonly="state !='new'" required="0"/>
						</h1>
					</group>
					<group name="group_between">
						<group>
							<field name="supplier" readonly="state !='new'" required="1"/>
						</group>
						<group>
							<field name="contract_type" readonly="state !='new'" required="0"/>

						</group>
					</group>
					<group name="group_2nd" string="Contract Validity">
						<group name="group_right">
							<group>
								<field name="date_start" readonly="state !='new'" required="1"/>
							</group>
							<group>
								<field name="date_end" readonly="state !='new'" required="0"/>
							</group>
						</group>
						<group name="group_left">
						</group>
					</group>
					<notebook>
						<page name = "contract_information" string = "Contract Information">
							<field name="product_detail" readonly="state !='new'" >
								<list editable="bottom" delete="false" >
									<field name="product" />
									<field name="season" />
									<field name="desc" />
								</list>
							</field>
						</page>
						<page name = "notes" string = "Notes">
							<field name="note" />
						</page>
					</notebook>
				</sheet>
			</form>
			</field>
		</record>
		<record id="contract_tree_view" model="ir.ui.view"> 
			<field name="name">Contract Tree View</field> 
			<field name="model">contract.form</field> 
			<field name="arch" type="xml"> 
			<list >
				<field name="name"/>
				<field name="supplier"/>
				<field name="contract_type"/>
				<field name="date_start"/>
				<field name="date_end"/>
			</list>
			</field>
		</record>
