<odoo>
    <data>
        <record id="quotation_builder_form_ext" model="ir.ui.view">
            <field name="name">quotation_builder_form_ext</field>
            <field name="model">quotation.builder</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="button_draft" string=" Draft" type="object" class="btn-primary" invisible="state =='draft'"  />
                        <button name="button_validate" string="Validate" type="object" class="btn-primary" invisible="state =='validate'" />
                        <button name="button_send_email_now" string="Send E-mail" type="object" class="btn-secondary" invisible="state =='draft'"  />
                        <button name="reservation_button_link" string="Generate Quotation Builder Link" type="object" class="oe_highlight"  />
                        <button name="action_create_reservation" string="Create Reservation" type="object" class="oe_highlight" invisible="state =='draft' or reservation_count != 0"/>
                        
                        <field name="state" widget="statusbar" statusbar_visible="draft,validate" />
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box" invisible="reservation_count == 0">
                            <button name="action_view_related_reservations" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
                                <field name="reservation_count" widget="statinfo" string="Reservations" />
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="sr_no" readonly="0" />
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="client_name"  readonly="state =='validate'" domain="[('b2c_customer', '=', 'true')]" required="1" />
                                <field name="subject" readonly="state =='validate'" required="1" />
                                <field name="create_uid" readonly="state =='validate'" invisible="1" />
                                <field name="date_from" readonly="state =='validate'" required="1" />
                                <field name='creation_date'  required="1" readonly="1" />
                                <field name='cancellation_days' readonly="state =='validate'" required="1" />
                                <field name='offers_validity_date' readonly="state =='validate'" required="0" />
                                <field name="partner_id_mtom" widget='many2many_tags' invisible="1" />
                            </group>
                            <group>
                                <field name="reference" readonly="1" force_save="1"/>
                                <field name="destination" widget='many2many_tags' readonly="state =='validate'" options="{'no_open':True,'no_create': True}" required="1" />
                                <field name="date_to" readonly="state =='validate'" />
                                <field name="maldives_website_link" />
                                <field name="number_of_guests" readonly="state =='validate'" />
                                <field name="total_in_report" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Booking">
                                <field name="tree_link_id" for_save="1" readonly="state =='validate'"  context="{'default_partner_id_mtom_parent':partner_id_mtom}">
                                    <list>
                                        <field name="drag" widget="handle" />
                                        <field name="partner_id_mtom_parent" column_invisible='1' options="{'no_open':True,'no_create': True}" />
                                        <field name="product_id" required='1' options="{'no_open':True,'no_create': True}" />
                                        <field name="supplier" required="0" domain="[('airline_supplier', '=', True), ('partner_type', '!=', 'customer')]" options="{'no_open': True, 'no_create': True}" column_invisible="0" />
                                       
                                        <field name="resort_name" required="0" domain="[('hotel_supplier','=',True)]" column_invisible="1"/>
                                        <field name="resort_map" widget="url" column_invisible="1"/>
                                        
                                        <field name="check_in" column_invisible="1" required="0" />
                                        <field name="check_out" column_invisible="1" />
                                       
                                        <field name="rate_hotel" column_invisible='0' />
                                        <field name="total" for_save="1" readonly="0" sum='Total' column_invisible='0' />
                                        
                                    </list>
                                    <form>
                                        <group invisible="service_type !='hotel'" >
                                            <group>
                                                
                                                <field name="partner_id_mtom_parent" invisible='1' options="{'no_open':True,'no_create': True}" />
                                                <field name="product_id" required="1" options="{'no_open':True,'no_create': True}" domain="[('prod_serv_typecategory','!=', False)]" />
                                                <field name="resort_name" required="service_type =='hotel'" domain="[('hotel_supplier','=',True), ('partner_type', '!=', 'customer')]" options="{'no_open':True,'no_create': True}" />
                                                <field name="resort_map" widget="url" />
                                                <field name="check_in" required="0" />
                                                <field name="check_out" required="0" />
                                                <field name="supplier" required="service_type =='hotel'"  options="{'no_open':True,'no_create': True}" invisible="0" />
                                                <field force_save="1" name="customer_m2m" required='0' domain="[('id','in',partner_id_mtom_parent)]" options="{'no_create': True}" widget="many2many_tags" invisible="1" />
                                                <field name="cancellation_days" invisible="1" />
                                                <field name="booking_date" />
                                                <field name="meal_plane" widget='many2many_tags' />
                                                <field name="description" />
                                                <field name="city_id" />
                                                <field name="no_of_nights" required="service_type =='hotel'"  readonly="0" invisible="0" />
                                                <field name="number_of_rooms" required="service_type=='hotel'" />
                                              
                                                <field name="inclusion" options="{'no_open':True}" invisible='1' />
                                                <field name="offers_appiled" />
                                                <field name="pictures" widget="many2many_binary" />
                                            </group>
                                            <group>
                                                <field name="gender" invisible="1" />
                                             
                                                <field name="room_type" widget='many2many_tags' />
                                                <field name="no_of_guest" invisible='0' />
                                                <field name="transfer" widget='many2many_tags' />
                                                <field name="rate_hotel" options="{'no_open':True,'no_create': True}" invisible='0' />
                                                <field name="total" for_save="1" invisible='0' />
                                                
                                                <field name="tree_canelattions" />
                                            </group>
                                        </group>
                                        <group invisible="service_type !='flight'" >
                                            <group>
                                                <field name="product_id" required="1" options="{'no_open':True,'no_create': True}" domain="[('prod_serv_typecategory','=',False)]" />
                                                <field name="airline" required="service_type=='flight'" options="{'no_open':True,'no_create': True}" domain="[('airline_supplier','=',True)]" />

                                                <field name="supplier" required='1' domain="[('airline_supplier','=',True),('partner_type', '!=', 'customer')]" options="{'no_open':True,'no_create': True}" />

                                                <field name="from_loc" string="From" options="{'no_open':True}" />
                                                <field name="to_loc" string="To" options="{'no_open':True}" />
                                                <field name="fight_class" options="{'no_open':True}" />
                                                <field name="departures" required="service_type=='flight'" />
                                                <field name="arrival" />
                                                <field name="booking_date" />
                                                <field name="description" />
                                                <field name="offers_appiled" />
                                            </group>
                                            <group>
                                                <field name="airline_pnr" invisible="1" />
                                               
                                                <field name="no_of_guest" invisible='0' string="No. of Passengers"/>
                                                <field name="rate_hotel" options="{'no_open':True,'no_create': True}" invisible='0' />
                                                <field name="total" readonly='0' force_save='1' sum='Total' invisible='0' />
                                                <field name="itinarnay_return" invisible='1' />
                                                <field name="flights_return" invisible='1' />
                                                <field name="tree_canelattions" />
                                            </group>
                                            <group>
                                                <field name="pictures" widget="many2many_binary" />
                                            </group>
                                        </group>
                                        <group invisible="service_type !='transfer'" >
                                            <group>
                                                <field name="product_id" required="1" options="{'no_open':True,'no_create': True}" domain="[('prod_serv_typecategory','!=',False)]" />
                                                <field name="supplier" domain="[('transfer_supplier','=',True), ('partner_type', '!=', 'customer')]" invisible="0" required="service_type=='transfer'"  options="{'no_open':True,'no_create': True}" />
                                                <field force_save="1" name="customer_m2m" invisible="1" required='0' domain="[('id','in',partner_id_mtom_parent)]" options="{'no_create': True}" widget="many2many_tags" />
                                                <field name="customer" required='0' domain="[('id','in',partner_id_mtom_parent)]" options="{'no_create': True}" invisible="1" />
                                                
                                                <field name="booking_date" />
                                                <field name="cancellation_days" invisible="1" />
                                                <field name="confirmation_no" />
                                                <field name="pick_up_place" />
                                                <field name="drop_of_place" />
                                                <field name="date" />
                                                <field name="transfer_type" options="{'no_open':True}" />
                                                <field name="vehicle_type" options="{'no_open':True}" />
                                                <field name="description" />
                                                <field name="offers_appiled" />
                                            </group>
                                            <group>
                                                <field name="wait_time_policy" options="{'no_open':True}" />
                                                <field name="rent_car" />
                                                <field name="no_of_person" string="Hours" invisible="1" />
                                               
                                                <field name="currency_name" options="{'no_open':True,'no_create': True}" invisible='1' />
                                                
                                                <field name="rate_hotel" options="{'no_open':True,'no_create': True}" invisible='0' />
                                                <field name="total" readonly='0' force_save='1' sum='Total' invisible='0' />
                                                <field name="price" invisible='1' />
                                                <field name="commission_percentage" invisible='1' />
                                                <field name="commission" readonly='1' force_save='1' invisible='1' />
                                                <field name="tree_canelattions" />
                                            </group>
                                            <group>
                                                <field name="pictures" widget="many2many_binary" />
                                            </group>
                                        </group>
                                        <group invisible="service_type !='tour'">
                                            <group>
                                                <field name="product_id" required="1" options="{'no_open':True,'no_create': True}" domain="[('prod_serv_typecategory','!=',False)]" />
