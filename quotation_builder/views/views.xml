                                                <field name="currency_name" options="{'no_open':True,'no_create': True}" invisible='1' />
                                                <field name="price" invisible='1' />
                                                <field name="commission_percentage" invisible='1' />
                                                <field name="commission" readonly='1' force_save='1' invisible='1' />
                                                <field name="rate_hotel" options="{'no_open':True,'no_create': True}" invisible='0' />
                                                <field name="total" readonly='0' force_save='1' invisible='0' />
                                                <field name="tree_canelattions" />
                                            </group>
                                            <group>
                                                <field name="pictures" widget="many2many_binary" />
                                            </group>
                                        </group>
                                        <group invisible="service_type !='visa'" >
                                            <group>
                                                <field name="product_id" required="1" options="{'no_open':True,'no_create': True}" domain="[('prod_serv_typecategory','!=',False)]" />
                                                <field name="supplier" domain="[('visa_supplier','=',True), ('partner_type', '!=', 'customer')]" invisible="0" required="service_type =='visa'"  options="{'no_open':True,'no_create': True}" />

                                                <field force_save="1" name="customer_m2m" required='0' domain="[('id','in',partner_id_mtom_parent)]" invisible="1" options="{'no_create': True}" widget="many2many_tags" />
                                                <field name="booking_date" />
                                                <field name="date_from" required='0' />
                                                <field name="date_to" required='0' />
                                                <field name="cancellation_days" invisible="1" />
                                                <field name="customer" required='0' domain="[('id','in',partner_id_mtom_parent)]" options="{'no_create': True}" invisible="1" />
                                                <field name="confirmation_no" />
                                                <field name="description" />
                                                <field name="offers_appiled" />
                                            </group>
                                            <group>
                                                <field name="visa_status" />
                                                <field name="no_of_person" string="Ordered Qty" invisible="1" />
                                              
                                                <field name="price" invisible='1' />
                                                <field name="commission_percentage" invisible='1' />
                                                <field name="commission" readonly='1' force_save='1' invisible='1' />
                                                <field name="rate_hotel" options="{'no_open':True,'no_create': True}" invisible='0' />
                                                <field name="total" readonly='0' force_save='1' sum='Total' invisible='0' />
                                                <field name="tree_canelattions" />
                                            </group>
                                            <group>
                                                <field name="pictures" widget="many2many_binary" />
                                            </group>
                                        </group>
                                        <group invisible="service_type !='package'" >
                                            <group>
                                                <field name="product_id" required="1" options="{'no_open':True,'no_create': True}" domain="[('prod_serv_typecategory','!=',False)]" />
                                               <field name="supplier" invisible="0" required="service_type =='package'" domain="[('package_supplier','=',True), ('partner_type', '!=', 'customer')]" options="{'no_open':True,'no_create': True}" />
                                                <field force_save="1" name="customer_m2m" required='0' domain="[('id','in',partner_id_mtom_parent)]" invisible="1" options="{'no_create': True}" widget="many2many_tags" />
                                                <field name="customer" required='0' domain="[('id','in',partner_id_mtom_parent)]" options="{'no_create': True}" invisible="1" />
                                                <field name="booking_date" />
                                                <field name="cancellation_days" invisible="1" />
                                                <field name="category" required='0' readonly='0' />
                                                <field name="confirmation_no" />
                                                <field name="validity" />
                                                <field name="no_of_nights" />
                                                <field name="rooms_type" />
                                                <field name="meal_plan" options="{'no_open':True}" />
                                                <field name="transfer_mode" />
                                                <field name="description" />
                                                <field name="offers_appiled" />
                                            </group>
                                            <group>
                                                <field name="no_of_person" string="Guest No" invisible='1' />
                                                <field name="added_values" invisible='1' />
                                               
                                                <field name="price" invisible='1' />
                                                <field name="product_type" />
                                                <field name="commission_percentage" invisible='1' />
                                                <field name="commission" readonly='1' force_save='1' invisible='1' />
                                                <field name="rate_hotel" options="{'no_open':True,'no_create': True}" invisible='0' />
                                                <field name="total" readonly='0' force_save='1' sum='Total' invisible='0' />
                                                <field name="tree_canelattions" />
                                            </group>
                                            <group>
                                                <field name="pictures" widget="many2many_binary" />
                                            </group>
                                        </group>
                                        <group invisible="service_type !='private'" >
                                            <group>
                                                <field name="product_id" required="1" options="{'no_open':True,'no_create': True}" domain="[('prod_serv_typecategory','!=',False)]" />
                                                <field name="supplier" invisible="0" required="service_type=='private'"  domain="[('private_jet','=',True), ('partner_type', '!=', 'customer')]" options="{'no_open':True,'no_create': True}" />
                                                <field force_save="1" name="customer_m2m" required='0' domain="[('id','in',partner_id_mtom_parent)]" invisible="1" options="{'no_create': True}" widget="many2many_tags" />
                                                <field name="customer" required='0' domain="[('id','in',partner_id_mtom_parent)]" options="{'no_create': True}" invisible="1" />
                                                <field name="cancellation_days" invisible="1" />
                                                <field name="booking_date" />
                                                <field name="from_to" />
                                                <field name="flight" />
                                                <field name="fight_class" options="{'no_open':True}" />
                                                <field name="departures" />
                                                <field name="arrival" />
                                                <field name="description" />
                                                <field name="offers_appiled" />
                                            </group>
                                            <group>
                                                <field name="bag" />
                                                <field name="terminal" />
                                                <field name="airline_pnr" />
                                                <field name="no_of_person" invisible='1' />
                                               
                                                <field name="rate_hotel" options="{'no_open':True,'no_create': True}" invisible='0' />
                                                <field name="total" readonly='0' force_save='1' sum='Total' invisible='0' />
