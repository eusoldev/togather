<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- To add credential field inside the myfatoorah provider   -->
    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">payment.provider.view.form.inherit.myfatoorah.payment.gateway</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form" />
        <field name="arch" type="xml">
            <group name="provider_credentials" position='inside'>
                <group invisible="code != 'myfatoorah'">
                    <field name="myfatoorah_token" string="Token" required="code == 'myfatoorah' and state != 'disabled'" />
                </group>
            </group>
            <group name="payment_form" position="inside">
                <field name="myfatoorah_payment_method_ids"
                       invisible="code != 'myfatoorah'"
                       placeholder="2,6,11"/>
                <field name="myfatoorah_enable_refund"
                       invisible="code != 'myfatoorah'"/>
                <field name="myfatoorah_refund_service_charge_on_customer"
                       invisible="code != 'myfatoorah' or not myfatoorah_enable_refund"/>
                <field name="myfatoorah_refund_require_otp"
                       invisible="code != 'myfatoorah' or not myfatoorah_enable_refund"/>
                <field name="myfatoorah_refund_otp_validity_minutes"
                       invisible="code != 'myfatoorah' or not myfatoorah_enable_refund or not myfatoorah_refund_require_otp"/>
            </group>
        </field>
    </record>
</odoo>
