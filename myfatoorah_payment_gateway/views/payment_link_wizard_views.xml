<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_link_wizard_view_form_inherit_myfatoorah_payment_gateway" model="ir.ui.view">
        <field name="name">payment.link.wizard.form.inherit.myfatoorah.payment.gateway</field>
        <field name="model">payment.link.wizard</field>
        <field name="inherit_id" ref="payment.payment_link_wizard_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[2]" position="after">
                <group name="payment_infoo" string="Invoice Info" class="mt-n4">
                    <field name="invoice_name" invisible="res_model != 'account.move'" readonly="1" />
                    <field name="customer_name" invisible="res_model != 'account.move'" readonly="1" />
                    <field name="customer_email_display" invisible="res_model != 'account.move'" readonly="1" />
                    <field name="partner_mobile" invisible="res_model != 'account.move'" readonly="1" />
                    <field name="due_date" invisible="res_model != 'account.move'" readonly="1" />
                    <field name="link" string="Payment Link" readonly="1" invisible="res_model != 'account.move' or bool(warning_message)" widget="CopyClipboardChar" />
                </group>
            </xpath>
            <footer position="inside">
                <button name="action_send_payment_link_email" type="object" string="Send Email" class="btn btn-primary" invisible="res_model != 'account.move' or not partner_email or bool(warning_message)" />
            </footer>
        </field>
    </record>
</odoo>
