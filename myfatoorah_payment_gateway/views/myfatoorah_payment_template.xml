<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="myfatoorah_payment_gateway_failed_form" name="Myfatoorah Payment confirm failed form">
            <html>
                <head>
                    <title>MyFatoorah Payment Failed</title>
                    <style type="text/css">
                        body {
                            margin: 0;
                            font-family: Arial, sans-serif;
                            background: #f5f7fa;
                            color: #1f2937;
                        }
                        .mf-wrapper {
                            min-height: 100vh;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            padding: 24px;
                            box-sizing: border-box;
                        }
                        .mf-card {
                            width: 100%;
                            max-width: 520px;
                            background: #ffffff;
                            border-radius: 16px;
                            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
                            padding: 32px;
                            text-align: center;
                        }
                        .mf-badge {
                            width: 64px;
                            height: 64px;
                            margin: 0 auto 16px;
                            border-radius: 50%;
                            background: #fee2e2;
                            color: #b91c1c;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 28px;
                            font-weight: 700;
                        }
                        .mf-title {
                            margin: 0 0 12px;
                            font-size: 28px;
                            font-weight: 700;
                        }
                        .mf-text {
                            margin: 0 0 24px;
                            font-size: 15px;
                            line-height: 1.6;
                            color: #4b5563;
                        }
                        .mf-actions {
                            display: flex;
                            gap: 12px;
                            justify-content: center;
                            flex-wrap: wrap;
                        }
                        .mf-btn {
                            display: inline-block;
                            padding: 12px 18px;
                            border-radius: 10px;
                            text-decoration: none;
                            font-weight: 600;
                            font-size: 14px;
                            min-width: 140px;
                            box-sizing: border-box;
                        }
                        .mf-btn-primary {
                            background: #0f172a;
                            color: #ffffff;
                        }
                        .mf-btn-secondary {
                            background: #e5e7eb;
                            color: #111827;
                        }
                    </style>
                </head>
                <body>
                    <div class="mf-wrapper">
                        <div class="mf-card">
                            <div class="mf-badge">!</div>
                            <h1 class="mf-title">Payment Failed</h1>
                            <p class="mf-text">
                                We could not complete your MyFatoorah payment. Please go back and try again.
                            </p>
                            <div class="mf-actions">
                                <a href="javascript:history.back()" class="mf-btn mf-btn-secondary">Back</a>
                                <a href="/payment/status" class="mf-btn mf-btn-primary">Payment Status</a>
                            </div>
                        </div>
                    </div>
                </body>
            </html>
        </template>
    </data>
</odoo>
