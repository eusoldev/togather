<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_inherit_myfatoorah_payment_gateway" model="ir.ui.view">
        <field name="name">account.move.form.inherit.myfatoorah.payment.gateway</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@id='account_invoice_payment_btn']" position="after">
                <button name="action_generate_myfatoorah_payment_link"
                        type="object"
                        string="Generate Payment Link"
                        class="oe_highlight"
                        groups="myfatoorah_payment_gateway.group_myfatoorah_payment_link_manager"
                        invisible="move_type != 'out_invoice' or state != 'posted' or amount_residual == 0"/>
            </xpath>
        </field>
    </record>
</odoo>
