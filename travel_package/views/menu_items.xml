<?xml version="1.0"?>
<odoo>
  <data>

    <!-- Table Tabs menu actions -->

    <!-- Flight Services -->
    <record id="flight_services_form_view" model="ir.ui.view">
      <field name="name">flight_services_form_view</field>
      <field name="model">all.services</field>
      <field name="arch" type="xml">
        <form string="Flight Services">
          <sheet>
            <group>
              <group>
                <field name='airline' domain="[('airline_supplier','=',True)]" required='1'/>
                <field name='supplier'/>
                <field name='customer_m2m' domain="[('id','=',parent.partner_id_mtom)]" options="{'no_create': True}" widget="many2many_tags"/>
                <field name='customer' domain="[('id','=',parent.partner_id_mtom)]" options="{'no_create': True}" invisible="1"/>
                <field name='from_to'/>
                <field name='flight'/>
                <field name='fight_class'/>
                <field name='departures'/>
                <field name='arrival'/>
                <field name='bag'/>
                <field name='terminal'/>
              </group>
              <group>
                <field name='airline_pnr'/>
                <field name='no_of_person'/>
                <field name='amnt_fc'/>
                <field name='currency_name'/>
                <field name='exchange_rate'/>
                <field name='price'/>
                <field name='commission'/>
                <field name='total'/>
                <field name='itinarnay_return' invisible='1'/>
                <field name='flights_return' invisible='1'/>
              </group>
            </group>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <record model="ir.ui.view" id="flight_services_main_tree_view">
      <field name="name">Flights Services</field>
      <field name="model">all.services</field>
      <field name="arch" type="xml">
        <list>
          <field name="airline"/>
          <field name="supplier"/>
          <field name="customer_m2m"/>
          <field name="from_to"/>
          <field name="flight"/>
          <field name="fight_class"/>
          <field name="departures"/>
          <field name="arrival"/>
          <field name="bag"/>
          <field name="terminal"/>
          <field name="airline_pnr"/>
          <field name="no_of_person"/>
          <field name="amnt_fc"/>
          <field name="currency_name"/>
          <field name="exchange_rate"/>
          <field name="price"/>
          <field name="commission"/>
          <field name="total"/>
        </list>
      </field>
    </record>

    <record id="all_services_search_view" model="ir.ui.view">
      <field name="name">all_services_search_view</field>
      <field name="model">all.services</field>
      <field name="arch" type="xml">
        <search string="Services">
          <filter string="Check In" name="departures" domain="[]" context="{'group_by': 'departures'}"/>
          <filter string="Check Out" name="arrival" domain="[]" context="{'group_by': 'arrival'}"/>
        </search>
      </field>
    </record>
    
    <record id="action_service_flight" model="ir.actions.act_window">
      <field name="name">Flights Services</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">all.services</field>
      <field name="view_mode">list,graph,pivot,form</field>
      <field name="domain">[('service_type', '=','flight')]</field>
      <field name="context" eval="{'default_service_type': 'flight'}"/>
      <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id':ref('flight_services_main_tree_view')}), (0, 0, {'view_mode': 'form', 'view_id': ref('flight_services_form_view')})]"/>
    </record>
    

    <menuitem id="services_main_menu" parent="travel_package.main_menu" name="Package Services"  sequence="10" groups="security_group"/>
    <menuitem id="flight_service_menu" parent="services_main_menu" name="Flight Services"  sequence="1" groups="travel_package.security_group" action="action_service_flight"/>

    <!-- hotel Services -->
    <record id="hotel_services_form_view" model="ir.ui.view">
      <field name="name">hotel_services_form_view</field>
