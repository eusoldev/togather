<?xml version="1.0"?>
<odoo>
    <data>
        <record id="view_account_payment_form_ext" model="ir.ui.view">
            <field name="name">view_account_payment_form_ext</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form" />
            <field name="type">form</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='journal_id']" position="after">
                    <field name="journal_entry" readonly="1" invisible="journal_entry ==False" />
                    <field name="package_no" readonly="1" />
                </xpath>
            </field>
        </record>
    </data>
</odoo>