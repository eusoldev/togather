<?xml version="1.0"?>
<odoo>
    <data>
        <record id="mailing_template_field" model="ir.ui.view">
            <field name="name">mailing.template.field</field>
            <field name="model">mailing.mailing</field>
            <field name="inherit_id" ref="mass_mailing.view_mail_mass_mailing_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='subject']" position="after">
                    <field name="email_template" options="{'no_create_edit': True, 'no_open': True}" />
                </xpath>
            </field>
        </record>
    </data>
</odoo>