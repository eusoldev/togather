<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.module.category" id="module_password_access_rights" >
            <field name="name">Password Module</field>
            <field name="description">Category for password module</field>
    </record>

    <record model="res.groups.privilege" id="password_access_privilege">
        <field name="name">Password Module</field>
        <field name="category_id" ref="module_password_access_rights"/>
    </record>

    <record id="group_password_user_ext" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="password_access_privilege"/>
    </record>

    <record id="group_password_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="password_access_privilege"/>
        <field name="implied_ids" eval="[Command.link(ref('group_password_user_ext'))]"/>
    </record>


    <record id="only_request_user" model="ir.rule">
        <field name="name">Only Request User Can See</field>
        <field name="model_id" ref="model_password_module"/>
        <field name="groups" eval="[(4, ref('group_password_user_ext'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="domain_force">[('current_user','=',user.id)]</field>

    </record>

        <record id="only_request_manager" model="ir.rule">
        <field name="name">Only Request Manager Can See</field>
        <field name="model_id" ref="model_password_module"/>
        <field name="groups" eval="[(4, ref('group_password_admin'))]"/>
        <field name="domain_force">[]</field>
    </record>
</odoo>