<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="passsowrd_confirmations_wizard" model="ir.ui.view">
        <field name="name">Password Confirmation</field>
        <field name="model">password.confirmations</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Password Confirmation">
                <h2 style="margin-bottom:20px;" class="custom_close_now_form_view">Please enter your account password to proceed!</h2>
                <group name="group_left">
                    <field name="current_user" readonly="1" />
                    <field name="get_password" password="true" />
                </group>
                
                <footer style="height: 30px !important; border: none !important;">
                
                    <button name="get_password_confirmations" type="object" string="Confirm" class="oe_highlight" />

                    <button string="Cancel" class="btn-secondary" type="object" name="cancel_form_now" />
                
                </footer>
            </form>
        </field>
    </record>
    <record id="p_c_records_id" model="ir.actions.act_window">
        <field name="name">Password Confirmation</field>
        <field name="res_model">password.confirmations</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="passsowrd_confirmations_wizard" />
        <field name="target">new</field>
    </record>
</odoo>