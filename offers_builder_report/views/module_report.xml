<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="offers_builder_report">
            <t t-call="web.html_container">
                <t t-call="web.internal_layout">
                    <!-- <t t-call="web.external_layout_background"> -->
                    <t t-foreach="docs" t-as="o">
                        <div class="page">
                            <style type="text/css">
                            @media (min-width: 1200px) {
                                .container {
                                    width: 100%;
                                }
                            }

                            @media (min-width: 992px) {
                                .container {
                                    width: 100%;
                                }
                            }

                            @media (min-width: 768px) {
                                .container {
                                    width: 100%;
                                }
                            }

                            .container {
                                width: 100%;
                            }

                            body.o_in_iframe {
                                margin: 0px !important;
                                padding: 0px !important;
                            }

                            .header,
                            .footer {
                                display: none !important;
                            }

                            .main_wraper {
                                width: 1000px;
                                margin: 0px auto;
                            }

                            .main_div {
                                width: 100%;
                            }

                            .left_div {
                                width: 20%;
                                float: left;
                                font-size: 13px;
                                margin-left: 50px;
                            }

                            .right_div {
                                width: 43%;
                                float: left;
                                font-size: 13px;
                                margin-top: 150px;
                            }

                            .last_div {
                                width: 30%;
                                float: right;
                                margin-top: 70px;
                            }

                            .head_border {
                                border-bottom: 8px solid #eaded7 !important;
                            }

                            .right_div p {
                                margin: 0px;
                                font-size: 17px;
                            }

                            h4 {
                                text-align: center;
                                font-weight: bold;
                                font-size: 20px;
                            }

                            img {
                                max-width: 100%;
                                min-height: 140px;
                                max-height: 140px;
                                color: rgb(81, 203, 206);
                            }

                            .left_div img {
                                max-width: 100%;
							    min-height: 65px;
							    max-height: 240px;
							    margin-right: 150px;
							    margin-top: 125px;
							    color: rgb(81, 203, 206);
                            }

                            .last_div img {
                                    max-width: 100%;
								    min-height: 116px;
								    margin-top: 48px;
								    max-height: 135px;
                            }

                            .left_div_2 {
                                float: left;
                                width: 50%;
                                font-size: 13px;
                            }

                            .right_div_2 {
                                width: 50%;
                                float: left;
                                font-size: 13px;
                            }

                            .left_div_3 {
                                width: 95%;
                                float: left;
                                font-size: 13px;
                            }

                            .left_div p {
                                margin: 0px;
                            }

                            .solid_div {}

                            .liquid_div {
                                font-size: 12px;
                                width: 60%;
                                float: right;
                            }

                            .left_div_2 p {
                                margin: 0px;
                            }

                            .right_div_2 p {
                                margin: 0px;
                            }

                            table {
                                border-collapse: collapse;
                                border: 1px solid black;
                                margin-top: 5px;
                            }

                            th {
                                border-collapse: collapse;
                                font-size: 13px;
                                padding: 8px;
                                text-align: left;
                                font-weight: bold;
                                border: 1px solid black;
                                background: #eaded7;
                            }

                            td {
                                border-collapse: collapse;
                                font-size: 13px;
                                padding: 5px;
                                text-align: left;
                                border: 1px solid black;
                            }

                            .clear_float {
                                clear: both;
                                float: none;
                                height: 0px;
                                width: 0px;
                                display: block;
                            }

                            .head {
                                background-color: #eaded7;
                                margin: 4px;
                                font-size: 18px;
                                padding: 10px;
                                color: white;
                                font-weight: bold;
                                margin-top: 10px;
                            }

                            .term {
                                text-align: center;
                                font-size: 25px;
                                font-weight: bold;
                            }

                            .footer_logo {
                                width: 1100px;
                                margin: 0px auto;
                                text-align: center;
                            }

                            .arabic {
                                margin-right: 50px;
                            }
                            </style>
                            <div class="main_wraper">
                                <div>
                                    <div>
                                        <t t-foreach="company" t-as="c">
                                            <div class="main_div">
                                                <div class="left_div">
                                                    <t t-tif="c.logo">
                                                        <img t-if="c.logo" t-att-src="image_data_uri(c.logo)" style="float:left;" alt="Logo" />
                                                       
                                                    </t>
                                                </div>
                                                <div class="right_div">
                                                    <div class="head_border" />
                                                </div>
                                               
                                                <div class="last_div">
                                                    <img src="/offers_builder_report/static/src/img/logo.png" />
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                    <br class="clear_float" />
                                </div>
                                <br class="clear_float" />
                                <h4>
                                    <span t-esc="o.hotel.name"></span>
                                </h4>
                                <h4>
                                    <span t-esc="o.subject"></span>
                                </h4>
                                <h4>
                                    <span class="solid">Offer Validity From: </span>
                                    <t t-if="o.offer">
                                        <span t-esc="time.strftime('%d %B %Y',time.strptime(str(o.offer),'%Y-%m-%d'))"></span>
                                    </t>
                                </h4>
                                <h4>
                                    <span class="solid">Offer Validity To: </span>
                                    <t t-if="o.offer_to">
                                        <span t-esc="time.strftime('%d %B %Y',time.strptime(str(o.offer_to),'%Y-%m-%d'))"></span>
                                    </t>
                                </h4>
                                <h4>
                                    <img t-if="o.logo" t-att-src="image_data_uri(o.logo)" />
                                </h4>
                                <p>
                                    <b><span class="solid">Date From: </span></b>
                                    <t t-if="o.date_of_stay">
                                        <span t-esc="time.strftime('%d %B %Y',time.strptime(str(o.date_of_stay),'%Y-%m-%d'))"></span>
                                    </t>
                                </p>
                                <p>
                                    <b><span class="solid">Date To: </span></b>
                                    <t t-if="o.date_to">
                                        <span t-esc="time.strftime('%d %B %Y',time.strptime(str(o.date_to),'%Y-%m-%d'))"></span>
                                    </t>
                                </p>
                                <div class="page_set">
                                    <table width="100%">
                                        <tr>
                                            <th>Room Type</th>
                                            <t t-if="night_3">
                                                <th>3 Nights</th>
                                            </t>
                                            <t t-if="night_4">
                                                <th>4 Nights</th>
                                            </t>
                                            <t t-if="night_5">
                                                <th>5 Nights</th>
                                            </t>
                                            <t t-if="extra_adult">
                                                <th>Extra Night</th>
                                            </t>
                                        </tr>
                                        <t t-foreach="o.offers_builder_tree" t-as="off">
                                            <tr>
                                                <td>
                                                    <span t-esc="off.room_type.name"></span>
                                                </td>
                                                <t t-if="off.night_3">
                                                    <td>
                                                        <span t-esc="'{0:,.2f}'.format(float(off.night_3))"></span>
                                                    </td>
                                                </t>
                                                <t t-if="off.night_4">
                                                    <td>
                                                        <span t-esc="'{0:,.2f}'.format(float(off.night_4))"></span>
                                                    </td>
                                                </t>
                                                <t t-if="off.night_5">
                                                    <td>
                                                        <span t-esc="'{0:,.2f}'.format(float(off.night_5))"></span>
                                                    </td>
                                                </t>
                                                <t t-if="off.extra_adult">
                                                    <td>
                                                        <span t-esc="'{0:,.2f}'.format(float(off.extra_adult))"></span>
                                                    </td>
                                                </t>
                                            </tr>
                                        </t>
                                    </table><br />
                                    <table width="100%">
                                        <tr>
                                            <th>Supplement Type</th>
                                            <th>Price</th>
                                        </tr>
                                        <t t-foreach="o.supplement_type_tree" t-as="off">
                                            <tr>
                                                <td>
                                                    <span t-esc="off.supplement_type.name"></span>
                                                </td>
                                                <td>
                                                    <span t-esc="'{0:,.2f}'.format(float(off.price))"></span>
                                                </td>
                                            </tr>
                                        </t>
                                    </table><br /><br />
                                    <div>
                                        <p><b>Package Inclusions:</b></p>
                                        <p>
                                            <span t-raw="o.package_inclusions"></span>
                                        </p>
                                    </div>
                                    <div>
                                        <p><b>Exclusive Benefits:</b></p>
                                        <p>
                                            <span t-raw="o.exclusive_benefits"></span>
                                        </p>
                                    </div>
                                    <div>
                                        <p><b>Honeymooners Benefits:</b></p>
                                        <p>
                                            <span t-raw="o.honeymooners_benefits"></span>
                                        </p>
                                    </div>
                                    <div>
                                        <p><b>Terms &amp; Conditions:</b></p>
                                        <p>
                                            <span t-raw="o.terms_conditions"></span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!--end of page-->
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>