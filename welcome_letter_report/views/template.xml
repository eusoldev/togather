        <record id="welcome_letter_report_id" model="ir.actions.report">
            <field name="name">Welcome Letter</field>
            <field name="model">all.services</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">welcome_letter_report.flight_report_report</field>
            <field name="report_file">welcome_letter_report.flight_report_report</field>
            <field name="print_report_name">'Welcome Letter- %s' % (object.hotel_return.partner_id.name)</field>
            <field name="binding_model_id" ref="travel_package.model_all_services" />
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="voucher_report_template" />
        </record>

