<!-- <?xml version="1.0" encoding="utf-8"?> -->
<odoo>
    <data>
        <record id="paperformat_vat_report" model="report.paperformat">
            <field name="name">Page For Vat Report</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">10</field>
            <field name="dpi">90</field>
        </record>
        <!-- <report id="report_for_vat_report" model="account.move" name="vat_report.vat_report" file="vat_report.vat_report" report_type="qweb-pdf" string="Vat Report" paperformat="paperformat_vat_report" menu="False" />


         <report id="report_for_vat_report_xlsx" model="vat.report" name="vat_report.vat_report_xlsx" file="vat_report.vat_report_xlsx" report_type="xlsx" string="Vat Report"  menu="False" attachment_use="False" /> -->
        <record id="report_for_vat_report" model="ir.actions.report">
            <field name="name">Vat Report</field>
            <field name="model">vat.report</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">vat_report.vat_report</field>
            <field name="report_file">vat_report.vat_report</field>
            <field name="print_report_name">Vat Report</field>
            <field name="attachment" />
            <field name="binding_model_id" ref="vat_report.model_vat_report" />
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="paperformat_vat_report" />
        </record>
        <record id="report_for_vat_report_xlsx" model="ir.actions.report">
            <field name="name">Vat Report</field>
            <field name="model">vat.report</field>
            <field name="report_type">xlsx</field>
            <field name="report_name">vat_report.vat_report_xlsx</field>
            <field name="report_file">vat_report.vat_report_xlsx</field>
            <field name="print_report_name">Vat Report</field>
            <field name="attachment" />
            <field name="binding_model_id" ref="vat_report.model_vat_report" />
        </record>
        <record id="vat_report_records_wizard" model="ir.ui.view">
            <field name="name">vat_report_records_wizard</field>
            <field name="model">vat.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report">
                    <group name="group_top">
                        <group name="group_left">
                            <field name="date_range" />
                            <field name="form" />
                        </group>
                        <group name="group_right">
                            <!-- <field name="financial_year"/> -->
                            <field name="print_excel" />
                            <field name="to" />
                        </group>
                    </group>
                    <footer style="height: 30px !important; border: none !important;">
                        <button name="generate_report" type="object" string="Print" class="oe_highlight" />
                    </footer>
                </form>
            </field>
        </record>
        <record id="vat_report_menu_action" model="ir.actions.act_window">
            <field name="name">Vat Report</field>
            <field name="res_model">vat.report</field>
            <!-- <field name="view_type">form</field> -->
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="vat_report_records_wizard" />
            <field name="target">new</field>
        </record>
        <record id="security_group_for_vat_report_id" model="res.groups">
            <field name="name">Security Group For Vat Report</field>
        </record>
        <menuitem id="vat_report_menu_item" name="Vat Report" action="vat_report_menu_action" parent="account.menu_finance_reports" groups="vat_report.security_group_for_vat_report_id" />
        <template id="vate_report_template">
            <style type="text/css">
        .voucher-company-header {
            width: 100%;
            min-height: 170px;
            padding: 28px 18px 18px 18px;
            border-bottom: 3px solid #d5dde7;
            box-sizing: border-box;
        }

        .voucher-company-info {
            float: left;
            width: 36%;
            color: #000;
            font-size: 12px;
            line-height: 1.35;
        }

        .voucher-company-info p,
        .voucher-company-info-ar p {
            margin: 0 !important;
            padding: 0 !important;
            font-size: 12px !important;
        }

        .voucher-company-info p.voucher-company-name,
        .voucher-company-info-ar p.voucher-company-name-ar {
            font-size: 20px !important;
            font-weight: 700;
            line-height: 1.2;
        }

        .voucher-logo-wrap {
            float: left;
            width: 28%;
            text-align: center;
            padding-top: 45px;
        }

        .voucher-logo-wrap img {
            max-width: 145px;
            max-height: 65px;
        }

        .voucher-company-info-ar {
            float: right;
            width: 36%;
            color: #000;
            direction: rtl;
            text-align: right;
            font-size: 12px;
            line-height: 1.35;
        }

        .clear_float {
            clear: both;
            float: none;
            height: 0;
            width: 0;
            display: block;
        }
        </style>
        <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" />
        <t t-if="not o" t-set="o" t-value="doc" />
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>
        <div class="o_background_header" style="min-height: 190px !important;">
            <div class="float-right">
                <h3 class="mt0 text-right" t-field="company.report_header" />
            </div>
            <div>
                <t t-foreach="company" t-as="c">
                    <t t-set="report_company" t-value="c" />
                    <div class="voucher-company-header">
                        <div class="voucher-company-info">
                            <p class="voucher-company-name">
                                <span t-esc="report_company.name" />
                            </p>
                            <p style="font-size:12px">
                                <span t-if="report_company.street" t-esc="report_company.street" />
                                <span t-if="report_company.street and (report_company.city or report_company.country_id)">, </span>
                                <span t-if="report_company.city" t-esc="report_company.city" />
                                <span t-if="report_company.city and report_company.country_id">, </span>
                                <span t-if="report_company.country_id" t-esc="report_company.country_id.name" />
                            </p>
                            <p t-if="report_company.email" style="font-size:12px">
                                <span t-esc="report_company.email" />
                            </p>
                            <p t-if="report_company.phone" style="font-size:12px">
                                <span t-esc="report_company.phone" />
                            </p>
                            <p t-if="report_company.vat" style="font-size:12px">
                                <span t-esc="report_company.vat" />
                            </p>
                            <p t-if="report_company.custom_cr_number" style="font-size:12px">
                                <span>CR Number </span>
                                <span t-esc="report_company.custom_cr_number" />
                            </p>
                        </div>
                        <div class="voucher-logo-wrap">
                            <img t-if="report_company.logo" t-att-src="image_data_uri(report_company.logo)" />
                        </div>
                        <div class="voucher-company-info-ar">
                            <p class="voucher-company-name-ar">
                                <span t-esc="report_company.arabic_contact" />
                            </p>
                            <p style="font-size:12px !important;">
                                <t t-if="report_company.arabic_street">
                                    <span t-esc="report_company.arabic_street" />
                                </t>
                                <t t-if="report_company.arabic_street2">
                                    <t t-if="report_company.arabic_street">, </t>
                                    <span t-esc="report_company.arabic_street2" />
                                </t>
                                <t t-if="report_company.arabic_city">
                                    <t t-if="report_company.arabic_street or report_company.arabic_street2">, </t>
                                    <span t-esc="report_company.arabic_city" />
                                </t>
                                <t t-if="report_company.arabic_country">
                                    <t t-if="report_company.arabic_street or report_company.arabic_street2 or report_company.arabic_city">, </t>
                                    <span t-esc="report_company.arabic_country" />
                                </t>
                                <t t-if="report_company.arabic_state">
                                    <t t-if="report_company.arabic_street or report_company.arabic_street2 or report_company.arabic_city">, </t>
                                    <span t-esc="report_company.arabic_state" />
                                </t>
                            </p>
                            <p t-if="report_company.email" style="font-size:12px !important;">
                                <span t-esc="report_company.email" />
                            </p>
                            <p t-if="report_company.phone" style="font-size:12px !important;">
                                <span t-esc="report_company.phone" />
                            </p>
                            <p t-if="report_company.arabic_vat" style="font-size:12px !important;">
                                <span t-esc="report_company.arabic_vat" />
                            </p>
                            <p t-if="report_company.arabic_cr_number" style="font-size:12px !important;">
                                <span t-esc="report_company.arabic_cr_number"/>
                            </p>
                        </div>
                        <br class="clear_float" />
                    </div>
                </t>
            </div>
        </div>
        <t t-raw="0" />
        </template>
    </data>
</odoo>