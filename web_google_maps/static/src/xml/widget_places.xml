<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="web_google_maps.GplaceAddressAutocompleteField">
        <t t-if="props.readonly">
            <span t-esc="props.record.data[props.name]"/>
        </t>
        <t t-else="">
            <input
                type="text"
                class="o_input"
                t-att-id="props.id"
                t-att-placeholder="props.placeholder"
                t-ref="input"
                t-att-value="props.record.data[props.name] || ''"
                t-on-change="(ev) => this.props.record.update({ [this.props.name]: ev.target.value })"
            />
        </t>
    </t>
</templates>
