<odoo>
  

     <record id="add_voucher_email_template" model="mail.template">
            <field name="name">Voucher Email Template</field>
            <field name="model_id" ref="travel_package.model_reservation_order" />
            <field name="subject">Ref {{ object.name or 'n/a' }})</field>
            <field name="email_from">{{ (object.user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="report_template_ids" eval="[(4, ref('voucher_report.voucher_report_pdf_id'))]" />
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                     <p>Hi</p>
                    <br />
                    <p>Here is the details of open invoices</p>
                    <br />
                </div>
            </field>
            <!-- <field name="lang">{{ object.partner_id.lang }}</field> -->
        </record>
</odoo>