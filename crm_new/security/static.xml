<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.module.category" id="module_crm_access_rights">
        <field name="name">CRM Module</field>
        <field name="description">Category for Crm module</field>
    </record>
    <record model="res.groups.privilege" id="crm_access_privilege">
        <field name="name">CRM Module</field>
        <field name="category_id" ref="module_crm_access_rights"/>
    </record>
    <record id="group_crm_user_ext" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="crm_access_privilege"/>
    </record>
    <record id="group_crm_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="crm_access_privilege"/>
        <field name="implied_ids" eval="[Command.link(ref('group_crm_user_ext'))]"/>
    </record>
    <record id="only_request_manager_crm_user" model="ir.rule">
        <field name="name">CRM admin/user</field>
        <field name="model_id" ref="model_crm_lead" />
        <field name="domain_force">[('id','in',user.get_related_crm_records_now())]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>
</odoo>