        <template id="custom_sales_report">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-call="custom_sales_report.custom_sales_report_template">
                        <div class="page">
                            <style type="text/css">
                            @media (min-width: 992px) .container {
                                width: 100%;
                            }

                            @media (min-width: 768px) .container {
                                width: 100%;
                            }

                            .container {
                                width: 100%;
                            }

                            body {
                                margin: 0px !important;
                            }

                            body.o_in_iframe {
                                margin-top: 0px !important;
                            }

                            .header,
                            .footer {
                                display: none !important;
                            }


                            .p_div {
                                font-weight: bold;
                            }

                            .sale_div {
                                text-align: center;
                                font-weight: bold;
                                font-size: 25px;
                            }

                            table {
                                border-collapse: collapse;
                                border: 1px solid black;
                                background: 1px solid gray;
                            }

                            th {
                                border-collapse: collapse;
                                border: 1px solid black;
                                text-align: center;
                                font-weight: bold;
                                padding: 10px;
                                font-size: 13px;
                                background: #eaded7 !important;
                                color: #3d3838;
                            }

                            .bg_col {
                                background: gainsboro;
                            }

                            td {
                                border-collapse: collapse;
                                border: 1px solid black;
                                text-align: center;
                                padding: 10px;
                                font-size: 12px;
                            }

                            .right_td {
                                text-align: right;
                                padding-right: 6px;
                            }

                            .main_box {
                                width: 100%;
                            }

                            .box_a {
                                width: 50%;
                                float: left;
                                display: inline-block;
                            }

                            .box_b {
                                float: left;
                                width: 50%;
                                display: inline-block;
                                margin-bottom: 10px;
                            }



                            .span_custom img {
                                width: 70px !important;
                                height: 70px !important;
                                float: right;
                            }

                            h5 {
                                margin: 5px;
                                font-weight: 500;
                                margin-bottom: 10px;
                            }

                            .clearfloat {
                                clear: both;
                                float: none;
                                width: 100%;
                                height: 1px;
                                display: block;
                            }

                            .agent {
                                float: right;
                                display: inline-block;
                                width: 65%;
                            }


                            .agent_custom {

                                width: 70% !important;
                            }

                            .agent_dept {
                                float: right;
                                display: inline-block;
                                width: 79%;
                            }

                            .agent_div {
                                float: right;
                                display: inline-block;
                                width: 65%;
                            }

                            .main_div {
                                width: 100%;
                            }

                            .left_div {
                                float: left;
                                font-size: 13px;
                                width: 50%;
                            }

                            .right_div {
                                width: 50%;
                                float: left;
                                font-size: 13px;
                            }

                            .solid_div {
                                font-weight: bold,
                            }


                            .th_width {
                                width: 8%;
                                min-width: 8%;
                                max-width: 8%;
                            }
