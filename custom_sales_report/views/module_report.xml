                                                        <th>Sales Person</th>
                                                        <t t-if="a['type'] != 'Flight'">
                                                            <th>Check In</th>
                                                            <th>Check Out</th>
                                                        </t>
                                                        <th t-if="a['type'] == 'Hotel'">Hotel Name</th>
                                                        <th t-if="a['type'] == 'Flight'">Flight Name</th>
                                                        <th>Destination</th>
                                                        <th t-if="a['type'] == 'Hotel'">Villa Type</th>
                                                        <th>Book Date </th>
                                                        <th class="th_width">Arrival Date</th>
                                                        <th>Departure Date</th>
                                                        <th t-if="a['type'] == 'Hotel'">Number of Nights</th>
                                                        <th style="width:8%;">Guest name</th>
                                                        <th>Net</th>
                                                        <th class="th_width">Net Amount FC</th>
                                                        <th class="th_width">Commission</th>
                                                        <th>Total</th>
                                                        <!-- </t> -->
                                                    </tr>
                                                </thead>
                                                <t t-set="totalnight" t-value="0" />
                                                <t t-set="totalnet" t-value="0" />
                                                <t t-set="totalnetfc" t-value="0" />
                                                <t t-set="totalcommission" t-value="0" />
                                                <t t-set="totalamount" t-value="0" />
                                                <!--  <t t-foreach="o.emp_main_list" t-as="e">
                                                        <t t-foreach="e.main_list" t-as="m"> -->
                                                <t t-foreach="e['main_list']" t-as="o">
                                                    <tbody>
                                                        <tr>
                                                            <td>
                                                                <span t-esc="o['rq_number']"></span>
                                                            </td>
                                                            <td>
                                                            </td>
                                                            <td>
                                                                <span t-esc="o['sale_person']"></span>
                                                            </td>
                                                            <t t-if="a['type'] != 'Flight'">
                                                                <td>
                                                                    <span t-esc="o['date_from']"></span>
                                                                </td>
                                                                <td>
                                                                    <span t-esc="o['date_to']"></span>
                                                                </td>
                                                            </t>
                                                            <td t-if="a['type'] == 'Flight'">
                                                                <span t-esc="o['flight_name']"></span>
                                                            </td>
                                                            <td t-if="a['type'] == 'Hotel'">
                                                                <span t-esc="o['hotel_name']"></span>
                                                            </td>
                                                            <td>
                                                                <t t-foreach="o['destination']" t-as="des">
                                                                    <span t-esc="des" />
                                                                </t>
                                                            </td>
                                                            <td t-if="a['type'] == 'Hotel'">
                                                                <t t-foreach="o['room_type']" t-as="x">
                                                                    <span t-esc="x"></span>
                                                                    <br />
                                                                </t>
                                                            </td>
                                                            <td>
                                                                <span t-esc="o['date_order']" t-options="{'widget': 'datetime'}"></span>
                                                            </td>
                                                            <td>
                                                                <span t-esc="o['arrival_date']"></span>
                                                            </td>
                                                            <td>
                                                                <span t-esc="o['departure_date']"></span>
                                                            </td>
                                                            <td t-if="a['type'] == 'Hotel'">
                                                                <span t-esc="o['no_of_nights']"></span>
                                                                <t t-set="totalnight" t-value="totalnight + o['no_of_nights']" />
                                                            </td>
                                                            <td>
                                                                <span t-esc="o['guest_name']"></span>
                                                            </td>
                                                            <td>
                                                                <span t-esc="'{0:,}'.format(int(o['net']))"></span>
                                                                <t t-set="totalnet" t-value="totalnet + o['net']" />
                                                            </td>
                                                            <td>
                                                                <span t-esc="'{0:,}'.format(int(o['net_fc']))"></span>
                                                                <t t-set="totalnetfc" t-value="totalnetfc + o['net_fc']" />
                                                            </td>
                                                            <td>
                                                                <span t-esc="'{0:,}'.format(int(o['commission']))"></span>
                                                                <t t-set="totalcommission" t-value="totalcommission + o['commission']" />
                                                            </td>
                                                            <td>
                                                                <span t-esc="'{0:,}'.format(int(o['total']))"></span>
                                                                <t t-set="totalamount" t-value="totalamount + o['total']" />
                                                            </td>
                                                        </tr>
                                                    </tbody>
